{
  "name": "sharefrom",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "build": "npm run build:only",
    "build:only": "vite build",
    "deploy": "npm run build && wrangler deploy",
    "dev": "npm run format && npm run test && npm run build:only",
    "dev:run": "npm run build && wrangler dev --live-reload",
    "format": "npm run lint -- --fix",
    "lint": "eslint",
    "postinstall": "npm run build:only",
    "prebuild": "npm run lint",
    "prelint": "npm run typecheck",
    "preview": "vite preview",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:ui": "vitest --ui",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit && tsc --project worker/tsconfig.json"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "4.20260317.1",
    "@vitest/ui": "4.1.2",
    "eslint": "10.1.0",
    "eslint-config-andrewaylett": "6.1.0",
    "happy-dom": "20.8.9",
    "jsdom": "27.4.0",
    "typescript": "5.9.3",
    "vite": "7.3.1",
    "vitest": "4.1.2",
    "wrangler": "4.77.0"
  },
  "dependencies": {
    "@plausible-analytics/tracker": "0.4.4",
    "@types/qrcode": "1.5.6",
    "qrcode": "1.5.4"
  }
}
